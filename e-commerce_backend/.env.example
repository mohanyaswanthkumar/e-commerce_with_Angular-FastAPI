# ===================== APP =====================
APP_NAME=ecommerce-backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ===================== SECURITY / JWT =====================
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ===================== DATABASE (MySQL) =====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=ecom_user
DB_PASSWORD=ecom_password
DB_NAME=ecommerce_db
DATABASE_URL=mysql+pymysql://ecom_user:ecom_password@localhost:3306/ecommerce_db

# ===================== KAFKA =====================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=ecommerce-backend
KAFKA_GROUP_ID=ecommerce-backend-group
KAFKA_TOPIC_ORDER_PLACED=order.placed
KAFKA_TOPIC_ORDER_CONFIRMED=order.confirmed
KAFKA_TOPIC_STOCK_UPDATED=stock.updated
KAFKA_TOPIC_PAYMENT_EVENTS=payment.events
KAFKA_TOPIC_NOTIFICATION_EVENTS=notification.events
KAFKA_ENABLED=true

# ===================== SAP S/4HANA RAP (OData V4) =====================
SAP_BASE_URL=https://sap-s4hana.example.com
SAP_ODATA_SERVICE_PATH=/sap/opu/odata4/sap/api_sales_order/srvd/sap/zui_sales_order/0001
SAP_AUTH_TYPE=oauth2
SAP_OAUTH_TOKEN_URL=https://sap-s4hana.example.com/sap/bc/sec/oauth2/token
SAP_OAUTH_CLIENT_ID=CHANGE_ME
SAP_OAUTH_CLIENT_SECRET=CHANGE_ME
SAP_OAUTH_SCOPE=ZUI_SALES_ORDER_0001
SAP_BASIC_USER=CHANGE_ME
SAP_BASIC_PASSWORD=CHANGE_ME
SAP_REQUEST_TIMEOUT_SECONDS=15
SAP_MAX_RETRIES=3

# ===================== CORS =====================
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# ===================== EMAIL (for password change notification) =====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=no-reply@example.com
